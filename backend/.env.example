# 数据库连接串（asyncpg 驱动）。docker-compose 内主机名为 postgres
DATABASE_URL=postgresql+asyncpg://quizforge:quizforge@postgres:5432/quizforge

# Redis 连接串（Celery broker / 任务状态存储）。compose 内主机名为 redis
REDIS_URL=redis://redis:6379/0

# JWT 签名密钥，生产环境务必替换为随机长字符串
SECRET_KEY=change-me-in-production

# access_token 有效期（分钟），默认 24 小时
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# DeepSeek API Key（必填，否则 AI 出题会失败）
DEEPSEEK_API_KEY=

# DeepSeek API 地址（兼容 OpenAI 接口）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名称
DEEPSEEK_MODEL=deepseek-chat

# 上传文件保存目录
FILE_UPLOAD_DIR=./uploads

# 单个上传文件大小上限（MB）
MAX_UPLOAD_SIZE_MB=20
